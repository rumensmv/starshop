{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }} Starshop
{% endblock %}
{% block body %}
<h1><strong>Hello World !</strong></h1>

<div>
    <p>Nous possédons une flotte de {{ ships|length }} vaisseaux spaciaux ! </p>
    {%  if ships|length > 40  %}
        <p>
            C'est une flotte considérable !
        </p>
    {% endif %}
</div>

<div>
    <table>
        <tr>
            <th>Name</th>
            <td>
                <a href="{{ path('app_starship_show', { id: myShip.id }) }}">
                {{ myShip.name }}
            </td>
        </tr>
    </table>
</div>
{% endblock %}